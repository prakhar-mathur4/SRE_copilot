# SRE Copilot Environment Configuration

# OpenAI API Key for AI RCA (Required)
OPENAI_API_KEY=your_openai_api_key_here

# Prometheus Provider (Optional)
# Set this to your central Prometheus instance for VM monitoring
PROMETHEUS_URL=http://localhost:9090

# Alertmanager Webhook (Optional)
# If integrating with MS Teams
TEAMS_WEBHOOK_URL=

# Application Settings
DEBUG=False

# Monitored Services
# Comma-separated list of process names to track on the local machine/VM (e.g., "nginx,python,node")
# If empty, all active processes are retrieved.
MONITORED_SERVICES=nginx,python,node,uvicorn

# Confluence Runbooks Integration (Optional)
# Enables the Runbooks view and AI-grounded runbook suggestions in the Control Room.
# CONFLUENCE_TYPE: cloud | self-hosted
CONFLUENCE_TYPE=cloud
CONFLUENCE_URL=https://yourcompany.atlassian.net
CONFLUENCE_EMAIL=your-email@company.com
CONFLUENCE_API_TOKEN=your_confluence_api_token_here
# Paste the full URL of the parent Confluence page under which all runbook pages live.
CONFLUENCE_ROOT_PAGE_URL=https://yourcompany.atlassian.net/wiki/spaces/SRE/pages/123456789/Runbooks
